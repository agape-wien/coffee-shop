# Development defaults — copy to .env and adjust as needed.
# For production (Pi deployment), see notes below each variable.

POSTGRES_USER=coffee
POSTGRES_PASSWORD=coffee          # Production: use a strong password
POSTGRES_DB=coffeedb

# Service name 'db' matches the Docker Compose service — works in both dev and prod.
DATABASE_URL=postgresql://coffee:coffee@db:5432/coffeedb

# Socket.io CORS origin.
# Development: set to the Vite dev server origin.
# Production: set to the Pi's IP/hostname (e.g. http://192.168.1.50) or * for local-network-only deployments.
CLIENT_URL=http://localhost:5173

JWT_SECRET=change_me_in_production   # Production: use a long random string

# First-run only — used once at startup to create the hashed password row in the database.
# After that this value is ignored; change the password via Management → Settings instead.
# To reset to this value: delete the AdminConfig row and restart the server (see README).
ADMIN_PASSWORD=change_me_in_production

NODE_ENV=development   # Production: set to production
PORT=3001
